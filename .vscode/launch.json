{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "linux-minishell",
			"type": "cppdbg",
			"request": "launch",
			"program": "${workspaceFolder}/minishell_debug",
			"args": [
				// if you want to pass arguments to your program
			],
			"stopAtEntry": false,
			"cwd": "${fileDirname}",
			"environment": [],
			"externalConsole": true,
			"preLaunchTask": "minishell-make",
			"linux": {
				"MIMode": "gdb",
				"miDebuggerPath": "/usr/bin/gdb"
			},
			"osx": {
				"MIMode": "lldb"
			},
		},
		{
			"name": "libft",
			"type": "cppdbg",
			"request": "launch",
			"program": "${workspaceFolder}/test/libft/libft_debug.out",
			"args": [
				// if you want to pass arguments to your program
			],
			"stopAtEntry": false,
			"environment": [],
			"preLaunchTask": "libft-make",
			"cwd": "${fileDirname}",
			"linux": {
				"MIMode": "gdb",
				"miDebuggerPath": "/usr/bin/gdb"
			},
			"osx": {
				"MIMode": "lldb"
			},
		},
		{
			"name": "linux-pipex",
			"type": "cppdbg",
			"request": "launch",
			"program": "${workspaceFolder}/test/pipex/pipex_debug.out",
			"args": [
				"${workspaceFolder}/test/pipex/infile.txt", "grep .c", "wc -l", "${workspaceFolder}/test/pipex/outfile.txt"
			],
			"stopAtEntry": false,
			"cwd": "${fileDirname}",
			"environment": [],
			"MIMode": "gdb",
			"preLaunchTask": "pipex-make",
			"linux": {
				"MIMode": "gdb",
				"miDebuggerPath": "/usr/bin/gdb"
			},
			"osx": {
				"MIMode": "lldb"
			},
		},
	]
}
