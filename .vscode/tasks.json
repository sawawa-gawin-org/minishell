{
    "tasks": [
		{
			"type": "cppbuild",
			"label": "minishell-make",
			"command": "make",
			"args": [
				"DEBUG_MODE=1",
				"-C", "${workspaceFolder}",
			],
			"options": {
				"cwd": "${fileDirname}"
			},
            "problemMatcher": [
                "$gcc"
            ],
			"group": "build",
		},
		{
			"type": "cppbuild",
			"label": "libft-make",
			"command": "make",
			"args": [
				"test", "DEBUG_MODE=1",
				"-C", "${workspaceFolder}/test/libft",
				"-j", "6"
			],
			"options": {
				"cwd": "${fileDirname}"
			},
            "problemMatcher": [
                "$gcc"
            ],
			"group": "build",
		},
		{
			"type": "cppbuild",
			"label": "dbllst-make",
			"command": "make",
			"args": [
				"test", "DEBUG_MODE=1",
				"-C", "${workspaceFolder}/test/dbllst",
				"-j", "6"
			],
			"options": {
				"cwd": "${fileDirname}"
			},
            "problemMatcher": [
                "$gcc"
            ],
			"group": "build",
		},
		{
			"type": "cppbuild",
			"label": "exec-make",
			"command": "make",
			"args": [
				"test", "DEBUG_MODE=1",
				"-C", "${workspaceFolder}/test/exec",
			],
			"options": {
				"cwd": "${fileDirname}"
			},
            "problemMatcher": [
                "$gcc"
            ],
			"group": "build",
		},
    ],
    "version": "2.0.0"
}
