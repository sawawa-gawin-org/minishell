{
	"version": "0.2.0",
	"compounds": [
		{
			"name": "tokens",
			"configurations": [
				"tokens(parser)",
				"tokens(expander)",
			]
		}
	],
	"configurations": [
		{
			"name": "minishell",
			"type": "cppdbg",
			"request": "launch",
			"program": "${workspaceFolder}/minishell_debug",
			"args": [
				// if you want to pass arguments to your program
			],
			"stopAtEntry": false,
			"cwd": "${workspaceFolder}",
			"environment": [],
			"externalConsole": true,
			"preLaunchTask": "minishell-make",
			"linux": {
				"MIMode": "gdb",
				"miDebuggerPath": "/usr/bin/gdb"
			},
			"osx": {
				"MIMode": "lldb",
				"environment": [
					{ "name": "DEBUGGER", "value": "vscode" }
				],
			},
		},
